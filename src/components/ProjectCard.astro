---
import Tag from './Tag.astro';
import { Github, ExternalLink } from 'lucide-astro';

const { project } = Astro.props;
---

<div class="group flex flex-col border border-gray-200/80 rounded-lg bg-white hover:border-gray-300 hover:shadow-[0_4px_24px_rgba(0,0,0,0.04)] hover:-translate-y-0.5 transition-all duration-300 ease-out h-full overflow-hidden">
  <!-- Top accent bar -->
  <div class="h-1 bg-gradient-to-r from-slate-800 to-slate-600 w-0 group-hover:w-full transition-all duration-500 ease-out"></div>

  <div class="p-6 flex flex-col flex-1">
    <!-- Header: title + icons -->
    <div class="flex justify-between items-start mb-3">
      <h3 class="text-lg font-semibold text-slate-900 leading-snug group-hover:text-slate-700 transition-colors duration-300 ease-out">{project.title}</h3>
      <div class="flex gap-2.5 items-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-out ml-4 pt-0.5 text-gray-400">
        <a class="hover:text-slate-800 transition-colors duration-200 cursor-pointer"><Github size={15} /></a>
        <a class="hover:text-slate-800 transition-all duration-300 ease-out cursor-pointer hover:translate-x-0.5 hover:-translate-y-0.5"><ExternalLink size={15} /></a>
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm text-gray-500 mb-6 leading-relaxed flex-1">{project.desc}</p>

    <!-- Footer: tech + highlight -->
    <div class="pt-4 border-t border-gray-100">
      <div class="flex gap-2 flex-wrap">
        {project.tech.map((t: string) => (
          <Tag>{t}</Tag>
        ))}
      </div>

      <!-- Highlight reveal (smooth max-height transition) -->
      <div class="max-h-0 overflow-hidden opacity-0 group-hover:max-h-12 group-hover:opacity-100 transition-all duration-500 ease-out mt-0 group-hover:mt-3">
        <p class="text-xs text-gray-400 font-mono">{project.highlight}</p>
      </div>
    </div>
  </div>
</div>

---
// about.astro
import Section from '../../layout/Section.astro'
import { MetaLabel, Divider } from '../../ui'
import { achievements } from '../../../data/navigation'
---

<Section
  id="about"
  title="About"
  heading="A bit about me"
>
  <div class="grid gap-12 md:grid-cols-5">
    <!-- Left: Narrative -->
    <div class="space-y-5 md:col-span-3">
      <p class="text-[15px] leading-[1.8] text-slate-600">
        I’m a frontend-focused full-stack developer with experience building
        scalable, production-grade web applications. Currently, I work on an
        AI-driven Governance, Risk & Compliance (GRC) platform, where I design
        and develop complex user interfaces, data-driven dashboards, and
        reusable component systems.
      </p>
      <p class="text-[15px] leading-[1.8] text-slate-600">
        I enjoy solving problems that sit at the intersection of performance,
        usability, and system design — turning complex workflows into simple,
        intuitive user experiences. While I’ve explored areas like Web3 and AI
        through projects, my core strength lies in building <strong
          >reliable, maintainable, and scalable web systems.</strong
        >
      </p>

      <!-- GitHub Contribution Graph -->
      <div class="pt-6">
        <MetaLabel class="mb-3">Contributions</MetaLabel>
        <a
          href="https://github.com/adarshswaminath"
          target="_blank"
          rel="noopener"
          class="overflow-x-auto"
        >
          <img
            src="https://ghchart.rshah.org/334155/adarshswaminath"
            alt="GitHub Contribution Graph"
            class="w-full opacity-80 transition-opacity duration-300 hover:opacity-100"
            loading="lazy"
          />
        </a>
      </div>
    </div>

    <!-- Right: Structured Metadata -->
    <div class="space-y-8 md:col-span-2">
      <div>
        <MetaLabel class="mb-3">Expertise</MetaLabel>
        <ul class="space-y-2">
          {
            [
              'Frontend Engineering',
              'System-Driven UI Development',
              'Developer Experience',
            ].map((expertise) => (
              <li class="list-disc text-[14px] text-slate-600">{expertise}</li>
            ))
          }
        </ul>
      </div>

      <Divider />

      <div>
        <MetaLabel class="mb-3">Focus Areas</MetaLabel>
        <ul class="space-y-2">
          {
            [
              'Performance-first architecture',
              'Clean, maintainable systems',
              'Scalable component systems',
              'Developer productivity & tooling',
            ].map((focusArea) => (
              <li class="list-disc text-[14px] text-slate-600">{focusArea}</li>
            ))
          }
        </ul>
      </div>

      <Divider />

      <div>
        <MetaLabel class="mb-3">Recognition</MetaLabel>
        <ul class="space-y-2">
          {
            achievements.map((a) => (
              <li class="list-disc text-[13px] text-slate-500">{a}</li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</Section>

---
// projects.astro
import Section from '../../layout/Section.astro';
import { Tag } from '../../ui';
import ProjectDrawer from '../../layout/ProjectDrawer.astro';
import { ArrowRight } from 'lucide-astro';
import { projects } from '../../../data/projects';
---
<Section id="projects" title="Projects" heading="Selected Works">
  <div class="space-y-0">
    {projects.map((p, i) => (
      <button
        class="project-row group w-full text-left flex items-center justify-between gap-6 py-5 border-b border-gray-200/80 hover:bg-white/50 transition-all duration-200 cursor-pointer -mx-4 px-4 rounded-lg"
        data-project-index={i}
      >
        <!-- Left: Title + Description -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-1">
            <h3 class="text-base font-medium text-slate-900 group-hover:text-slate-700 transition-colors">{p.title}</h3>
            <span class="text-[11px] text-gray-400 font-mono opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:inline truncate">
              {p.highlight}
            </span>
          </div>
          <p class="text-[13px] text-gray-500 leading-relaxed truncate">{p.desc}</p>
        </div>

        <!-- Right: Tech + Arrow -->
        <div class="flex items-center gap-4 shrink-0">
          <div class="hidden md:flex gap-1.5">
            {p.tech.map((t) => (
              <Tag class="text-[10px]">{t}</Tag>
            ))}
          </div>
          <ArrowRight size={16} class="text-gray-400 group-hover:text-slate-700 group-hover:translate-x-1 transition-all duration-200" />
        </div>
      </button>
    ))}
  </div>
</Section>

<!-- Project Drawer (rendered once, controlled by JS) -->
<ProjectDrawer projects={projects} />

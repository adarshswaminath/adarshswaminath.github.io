---
// experience.astro
import { experiences } from '../../../data/experiences';
---
<div id="experience" class="max-w-5xl mx-auto px-6 py-20 md:py-24">
  <div class="mb-14">
    <div class="flex items-center gap-4 mb-5">
      <div class="w-8 h-px bg-gray-300"></div>
      <span class="text-xs font-semibold tracking-[0.15em] text-gray-400 uppercase">Experience</span>
    </div>
    <h2 class="text-3xl md:text-[34px] font-medium text-gray-900 tracking-tight">Where I've worked</h2>
  </div>

  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-[5px] top-[8px] bottom-8 w-px bg-gray-200"></div>
    
    <div class="space-y-16">
      {experiences.map((exp, i) => (
        <div class="relative pl-10 md:pl-14">
          <!-- Timeline dot -->
          <div class={`absolute left-0 top-[8px] w-3 h-3 rounded-full bg-white border-2 ${i === 0 ? 'border-slate-800' : 'border-gray-300'}`}></div>
          
          <div class="mb-4">
            <h3 class="text-lg font-semibold text-slate-900">{exp.role}</h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-[14px] text-gray-600 font-medium">{exp.company}</span>
              <span class="text-gray-300">·</span>
              <span class="text-[13px] text-gray-400 font-mono tracking-tight">{exp.duration.toLowerCase()}</span>
            </div>
          </div>
          
          <div class="space-y-4">
            {exp.contributions.map((c) => (
              <p class="text-[14px] leading-[1.75] text-gray-600">{c}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

---
// experience.astro
import Section from '../../layout/Section.astro'
import { experiences } from '../../../data/experiences'
---

<Section
  id="experience"
  title="Experience"
  heading="Where I've worked"
>
  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute top-[8px] bottom-8 left-[5px] w-px bg-slate-200"></div>

    <div class="space-y-16">
      {
        experiences.map((exp) => (
          <div class="relative pl-10 md:pl-14">
            {/* <!-- Timeline dot --> */}
            <div
              class={`absolute top-[8px] left-0 h-3 w-3 rounded-full border-2 border-slate-800 bg-white`}
            />

            <div class="mb-4">
              <h3 class="text-lg font-semibold text-slate-900">{exp.role}</h3>
              <div class="mt-1 flex items-center gap-2">
                <span class="text-[14px] font-medium text-slate-600">
                  {exp.company}
                </span>
                <span class="text-slate-300">·</span>
                <span class="font-mono text-[13px] tracking-tight text-slate-400">
                  {exp.duration.toLowerCase()}
                </span>
              </div>
            </div>

            <div class="space-y-4">
              {exp.contributions.map((c) => (
                <p class="text-[14px] leading-[1.75] text-slate-600">{c}</p>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>

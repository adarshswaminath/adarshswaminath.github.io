---
// hero.astro
import { Button, Tag } from "../../ui";
import CodeWindow from "../../layout/CodeWindow.astro";
import { stackTags } from "../../../data/navigation";
---

<section class="max-w-5xl mx-auto px-6 py-20 md:py-32">
  <h1
    class="text-4xl md:text-5xl font-semibold mb-5 tracking-tight text-slate-900 leading-tight"
  >
    Building scalable, user-focused web applications
  </h1>
  <p class="text-slate-600 mb-8 text-lg max-w-2xl">
    Focused on performance, clean architecture, and developer experience.
  </p>
  <div class="flex gap-4 mb-8">
    <Button primary class="cursor-pointer">Projects</Button>
    <Button class="cursor-pointer">Contact Me</Button>
  </div>

  <div class="mb-4">
    <CodeWindow
      title="stack.ts"
      code={`const engineer = {
  name: "Adarsh",
  currently: "building AI-powered platforms",
  focus: [
    "scalable systems",
    "developer tooling",
    "clarity over complexity",
  ]
}

// let's build something great`}
      class="max-w-2xl"
    />
  </div>

  <div class="flex gap-2 mt-6 flex-wrap">
    {stackTags.map((t) => <Tag>{t}</Tag>)}
  </div>
</section>

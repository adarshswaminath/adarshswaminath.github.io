---
// hero.astro
import { Button, Tag } from '../../ui'
import CodeWindow from '../../layout/CodeWindow.astro'
import { stackTags } from '../../../data/navigation'
---

<section class="mx-auto max-w-5xl px-6 py-20 md:py-32">
  <h1
    class="mb-5 text-4xl leading-tight font-semibold tracking-tight text-slate-900 md:text-5xl"
  >
    Building scalable, user-focused web applications
  </h1>
  <p class="mb-8 max-w-2xl text-lg text-slate-600">
    Focused on performance, clean architecture, and developer experience.
  </p>
  <div class="mb-8 flex gap-4">
    <Button
      primary
      href="#projects"
      class="cursor-pointer"
      >Projects</Button
    >
    <Button
      href="#contact"
      class="cursor-pointer"
      >Contact Me</Button
    >
  </div>

  <div class="mb-4">
    <CodeWindow
      title="stack.ts"
      code={`const engineer = {
  name: "Adarsh",
  currently: "building AI-powered platforms",
  focus: [
    "scalable systems",
    "developer tooling",
    "clarity over complexity",
  ]
}

// let's build something great`}
      class="max-w-2xl"
    />
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {stackTags.map((t) => <Tag>{t}</Tag>)}
  </div>
</section>

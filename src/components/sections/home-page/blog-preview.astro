---
// blog-preview.astro — Featured blog posts list for the homepage
import Section from "../../layout/Section.astro";
import { ArrowRight } from "lucide-astro";

interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---

<Section id="blog" title="Blog" heading="Writing & Thoughts">
  <div class="space-y-0 mb-8">
    {
      posts.map((post: any) => (
        <a
          href={post.url}
          class="group flex items-center justify-between gap-6 py-5 border-b border-dashed border-slate-300 hover:bg-white/50 hover:-translate-y-[1px] transition-all duration-200 -mx-4 px-4 rounded-lg"
        >
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-1">
              <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-slate-400 bg-slate-100 px-2 py-0.5 rounded font-mono shrink-0">
                {post.frontmatter.category || "Article"}
              </span>
              <h3 class="text-[15px] font-medium text-slate-900 group-hover:text-slate-700 transition-colors truncate">
                {post.frontmatter.title}
              </h3>
            </div>
            <p class="text-[13px] text-slate-500 truncate leading-relaxed">
              {post.frontmatter.description}
            </p>
          </div>

          <div class="flex items-center gap-4 shrink-0">
            <span class="text-[12px] text-slate-400 font-mono hidden md:block">
              {new Date(post.frontmatter.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
            <ArrowRight
              size={14}
              class="text-slate-400 group-hover:text-slate-700 group-hover:translate-x-1 transition-all duration-200"
            />
          </div>
        </a>
      ))
    }
  </div>
  <a
    href="/blog"
    class="text-[13px] font-medium text-slate-500 hover:text-slate-800 transition-colors inline-flex items-center gap-1.5 group"
  >
    View all posts <ArrowRight
      size={13}
      class="group-hover:translate-x-1 transition-transform duration-200"
    />
  </a>
</Section>

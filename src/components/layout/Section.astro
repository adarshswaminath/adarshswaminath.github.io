---
import { TextAnimate } from '../ui/text-animate'

interface Props {
  id?: string
  title: string
  heading?: string
}
const { id, title, heading } = Astro.props
const headingText = heading ?? title
---

<section
  id={id}
  class="relative py-16"
>
  <div class="mx-auto max-w-5xl px-6">
    <header class="mb-10">
      <TextAnimate
        client:visible
        text={title}
        as="p"
        className="mb-2 text-xs tracking-wider text-slate-400 uppercase"
        by="word"
        animation="slideUp"
        once
        startOnView
      />
      <TextAnimate
        client:visible
        text={headingText}
        as="h2"
        className="text-2xl font-semibold text-slate-900"
        by="word"
        animation="blurInUp"
        delay={0.1}
        once
        startOnView
      />
    </header>
    <slot />
  </div>
</section>

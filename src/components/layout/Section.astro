---
// Section.astro
interface Props {
  id?: string;
  title: string;
  heading?: string;
}
const { id, title, heading } = Astro.props;
---

<section id={id} class="border-t border-dashed border-slate-300 py-16 relative">
  <div class="max-w-5xl mx-auto px-6">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-wider text-slate-400 mb-2">
        {title}
      </p>
      <h2 class="text-2xl font-semibold text-slate-900">
        {heading || title}
      </h2>
    </header>
    <slot />
  </div>
</section>

---
// Navbar.astro
import { navItems } from "../../data/navigation";
---

<nav
  class="sticky top-0 bg-[#F1F1F1]/90 backdrop-blur z-50 border-b border-slate-200"
>
  <div class="max-w-5xl mx-auto py-4 flex justify-between items-center">
    <a href="/" class="font-semibold text-slate-800">
      <img src="/icon.svg" alt="logo" class="size-8" />
    </a>
    <div class="flex gap-6 text-sm">
      {
        navItems.map((item) => (
          <a
            href={item === "Blog" ? "/blog" : `#${item.toLowerCase()}`}
            class="hover:underline cursor-pointer"
          >
            {item}
          </a>
        ))
      }
    </div>
  </div>
</nav>

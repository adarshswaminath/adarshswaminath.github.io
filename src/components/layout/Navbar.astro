---
// Navbar.astro
import { navItems } from '../../data/navigation'
---

<nav
  class="sticky top-0 z-50 border-b border-slate-200 bg-[#F1F1F1]/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4 lg:px-0"
  >
    <a
      href="/"
      class="font-semibold text-slate-800"
    >
      <img
        src="/icon.svg"
        alt="logo"
        class="size-8"
      />
    </a>
    <div class="flex gap-6 text-sm">
      {
        navItems.map((item) => (
          <a
            href={item === 'Blog' ? '/blog' : `/#${item.toLowerCase()}`}
            class="cursor-pointer text-slate-600 transition-colors hover:text-slate-900 hover:underline"
          >
            {item}
          </a>
        ))
      }
    </div>
  </div>
</nav>

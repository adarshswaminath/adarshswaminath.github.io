<div
  class="pointer-events-none fixed inset-y-0 z-50 flex w-full justify-center"
>
  <div class="relative h-full w-full max-w-5xl">
    <div
      class="absolute top-0 bottom-0 left-4 hidden w-[2px] py-24 sm:block md:left-[0.01rem]"
    >
      <!-- Glowing Dot -->
      <div
        id="tracing-beam-dot"
        class="absolute top-[88px] -left-[7px] flex h-4 w-4 items-center justify-center rounded-full border bg-white shadow-sm transition-all duration-300"
        style="border-color: rgba(0,0,0,0.24)"
      >
        <div
          id="tracing-beam-inner-dot"
          class="h-2 w-2 rounded-full border border-slate-900 bg-slate-800 transition-colors duration-300"
        >
        </div>
      </div>

      <svg
        class="h-full w-full overflow-visible"
        preserveAspectRatio="none"
        viewBox="0 0 2 100"
      >
        <!-- Background track -->
        <line
          x1="1"
          y1="0"
          x2="1"
          y2="100"
          stroke="#9091A0"
          stroke-opacity="0.16"
          stroke-width="1.5"
          vector-effect="non-scaling-stroke"
          stroke-linecap="round"
        ></line>

        <!-- Animated beam -->
        <line
          x1="1"
          y1="0"
          x2="1"
          y2="100"
          stroke="url(#tracing-gradient)"
          stroke-width="2"
          vector-effect="non-scaling-stroke"
          stroke-linecap="round"
        ></line>

        <defs>
          <linearGradient
            id="tracing-gradient"
            gradientUnits="userSpaceOnUse"
            x1="0"
            x2="0"
            y1="0"
            y2="-25"
          >
            <stop
              stop-color="#0f172a"
              stop-opacity="0"
            ></stop>
            <stop stop-color="#0f172a"></stop>
            <stop
              offset="0.325"
              stop-color="#334155"
            ></stop>
            <stop
              offset="1"
              stop-color="#94a3b8"
              stop-opacity="0"
            ></stop>
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>
</div>

---
import type { CodeLanguage } from 'astro'
import { Code } from 'astro:components'

interface Props {
  title?: string
  code: string
  lang?: CodeLanguage
  class?: string
}

const {
  title = 'stack.ts',
  code,
  lang = 'typescript',
  class: className = '',
} = Astro.props
---

<div
  class={`border border-slate-200/80 shadow-sm rounded-xl overflow-hidden flex flex-col ${className}`}
>
  <!-- Header -->
  <div
    class="relative flex items-center border-b border-slate-200/80 bg-[#f5f5f5] px-4 py-3"
  >
    <div class="relative z-10 flex gap-2">
      <div class="h-3 w-3 rounded-full bg-red-300"></div>
      <div class="h-3 w-3 rounded-full bg-yellow-300"></div>
      <div class="h-3 w-3 rounded-full bg-green-300"></div>
    </div>
    <div
      class="pointer-events-none absolute inset-0 flex items-center justify-center"
    >
      <span class="font-mono text-xs text-slate-400">{title}</span>
    </div>
  </div>
  <!-- Body -->
  <div
    class="code-window-body flex-1 overflow-x-auto bg-[#fdfdfd] p-6 font-mono text-sm"
  >
    <Code
      code={code}
      lang={lang}
      theme="github-light"
    />
  </div>
</div>

<style is:global>
  .code-window-body pre {
    background-color: transparent !important;
    margin: 0;
    padding: 0;
    font-family: inherit;
  }
</style>

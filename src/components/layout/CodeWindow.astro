---
import { Code } from "astro:components";

interface Props {
  title?: string;
  code: string;
  lang?: any;
  class?: string;
}

const {
  title = "stack.ts",
  code,
  lang = "typescript",
  class: className = "",
} = Astro.props;
---

<div
  class={`border border-slate-200/80 shadow-sm rounded-xl overflow-hidden flex flex-col ${className}`}
>
  <!-- Header -->
  <div
    class="bg-[#f5f5f5] border-b border-slate-200/80 px-4 py-3 flex items-center relative"
  >
    <div class="flex gap-2 relative z-10">
      <div class="w-3 h-3 rounded-full bg-red-300"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-300"></div>
      <div class="w-3 h-3 rounded-full bg-green-300"></div>
    </div>
    <div
      class="absolute inset-0 flex items-center justify-center pointer-events-none"
    >
      <span class="text-xs font-mono text-slate-400">{title}</span>
    </div>
  </div>
  <!-- Body -->
  <div
    class="p-6 font-mono text-sm overflow-x-auto flex-1 bg-[#fdfdfd] code-window-body"
  >
    <Code code={code} lang={lang} theme="github-light" />
  </div>
</div>

<style is:global>
  .code-window-body pre {
    background-color: transparent !important;
    margin: 0;
    padding: 0;
    font-family: inherit;
  }
</style>

---
// Section.astro
interface Props {
  id?: string;
  title: string;
  heading?: string;
}
const { id, title, heading } = Astro.props;
---
<section id={id} class="max-w-5xl mx-auto px-6 py-20 md:py-24">
  <div class="mb-14">
    <div class="flex items-center gap-4 mb-5">
      <div class="w-8 h-px bg-gray-300"></div>
      <span class="text-xs font-semibold tracking-[0.15em] text-gray-400 uppercase">{title}</span>
    </div>
    <h2 class="text-3xl md:text-[34px] font-medium text-gray-900 tracking-tight">{heading || title}</h2>
  </div>
  <slot />
</section>

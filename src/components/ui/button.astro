---
// button.astro — Primary/secondary button
interface Props {
  primary?: boolean;
  href?: string;
  class?: string;
}
const { primary, href, class: className = "" } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  class={`px-4 py-2 text-[15px] font-medium rounded-lg border transition-all duration-300 flex items-center justify-center ${
    primary
      ? "bg-slate-800 text-white border-slate-800 hover:opacity-90"
      : "border-slate-300 hover:border-slate-800"
  } ${className}`}
>
  <slot />
</Tag>

---
// meta-label.astro — Docs-style uppercase section label
// Used throughout: About metadata, Drawer sections, etc.
interface Props {
  class?: string
}
const { class: className = '' } = Astro.props
---

<h4
  class={`text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase font-mono ${className}`}
>
  <slot />
</h4>

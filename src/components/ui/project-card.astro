---
// project-card.astro — Compact redesign with Image Support
import type { Project } from "../../data/types";
import { ArrowUpRight } from "lucide-astro";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<button
  type="button"
  class="project-card project-row group relative p-3 rounded-xl border border-dashed border-slate-300 bg-white/40 hover:bg-white transition-all duration-300 flex flex-col gap-3 text-left w-full cursor-pointer"
  data-project-index={index}
>
  <!-- Image Area -->
  <div
    class="relative aspect-[16/10] rounded-lg border border-slate-200 overflow-hidden bg-slate-100 flex items-center justify-center"
  >
    {
      project.image ? (
        <img
          src={project.image}
          alt={project.title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full bg-slate-200 flex items-center justify-center">
          <ArrowUpRight size={24} class="text-slate-400 opacity-20" />
        </div>
      )
    }

    <!-- Hover Overlay -->
    <div
      class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/5 transition-colors duration-300"
    >
    </div>
  </div>

  <!-- Content Area -->
  <div class="flex flex-col gap-1.5 px-0.5">
    <div class="flex items-center justify-between gap-3">
      <h3
        class="text-[14px] font-bold text-slate-800 tracking-tight leading-none transition-colors"
      >
        {project.title}
      </h3>
    </div>

    <p class="text-[11.5px] text-slate-500 leading-snug line-clamp-2">
      {project.desc}
    </p>

    <div
      class="mt-0.5 pt-1 border-t border-transparent group-hover:border-slate-100 transition-colors"
    >
      <div
        class="text-[11px] font-semibold text-slate-400 group-hover:text-slate-900 flex items-center gap-1"
      >
        View Project
        <ArrowUpRight size={11} class="translate-y-[0.5px]" />
      </div>
    </div>
  </div>
</button>

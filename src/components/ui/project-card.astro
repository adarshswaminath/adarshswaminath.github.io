---
// project-card.astro — Compact redesign with Image Support
import type { Project } from '../../data/types'
import { ArrowUpRight } from 'lucide-astro'

interface Props {
  project: Project
  index: number
}

const { project, index } = Astro.props
---

<button
  type="button"
  class="project-card project-row group relative flex w-full cursor-pointer flex-col gap-3 rounded-xl border border-dashed border-slate-300 bg-white/40 p-3 text-left transition-all duration-300 hover:bg-white"
  data-project-index={index}
>
  <!-- Image Area -->
  <div
    class="relative flex aspect-[16/10] items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100"
  >
    {
      project.image ? (
        <img
          src={project.image}
          alt={project.title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-slate-200">
          <ArrowUpRight
            size={24}
            class="text-slate-400 opacity-20"
          />
        </div>
      )
    }

    <!-- Hover Overlay -->
    <div
      class="absolute inset-0 bg-slate-900/0 transition-colors duration-300 group-hover:bg-slate-900/5"
    >
    </div>
  </div>

  <!-- Content Area -->
  <div class="flex flex-col gap-1.5 px-0.5">
    <div class="flex items-center justify-between gap-3">
      <h3
        class="text-[14px] leading-none font-bold tracking-tight text-slate-800 transition-colors"
      >
        {project.title}
      </h3>
    </div>

    <p class="line-clamp-2 text-[11.5px] leading-snug text-slate-500">
      {project.desc}
    </p>

    <div
      class="mt-0.5 border-t border-transparent pt-1 transition-colors group-hover:border-slate-100"
    >
      <div
        class="flex items-center gap-1 text-[11px] font-semibold text-slate-400 group-hover:text-slate-900"
      >
        View Project
        <ArrowUpRight
          size={11}
          class="translate-y-[0.5px]"
        />
      </div>
    </div>
  </div>
</button>

---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Section from '../../components/Section.astro';
import { ArrowUpRight, Calendar } from 'lucide-astro';

// Fetch all markdown posts
const posts = Object.values(import.meta.glob('./*.md', { eager: true }));

// Sort by date DESC
const sortedPosts = posts.sort((a: any, b: any) => 
  new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<Layout title="Blog | Adarsh.dev">
  <nav class="sticky top-0 bg-[#F1F1F1]/90 backdrop-blur border-b border-gray-200 z-50">
    <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center text-sm">
      <a href="/" class="font-semibold text-gray-800">Adarsh.dev</a>
      <a href="/" class="hover:underline text-gray-600">Back Home</a>
    </div>
  </nav>

  <Section title="Writing & Thoughts">
    <p class="text-gray-600 mb-10 max-w-2xl">
      Articles on Web3, React, scalable systems architecture, and my journey as a developer.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {sortedPosts.map((post: any) => (
        <a href={post.url} class="group flex flex-col border border-gray-200/80 rounded-lg bg-white hover:border-gray-300 hover:shadow-[0_4px_24px_rgba(0,0,0,0.04)] hover:-translate-y-0.5 transition-all duration-300 block relative overflow-hidden">
          
          <!-- Top colored accent bar -->
          <div class="h-1 bg-gradient-to-r from-slate-800 to-slate-600 w-0 group-hover:w-full transition-all duration-500"></div>
          
          <div class="p-6 flex flex-col flex-1">
            <!-- Category pill -->
            <div class="mb-4">
              <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-500 bg-gray-100 px-2 py-1 rounded">
                {post.frontmatter.category || "Article"}
              </span>
            </div>

            <!-- Title -->
            <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-slate-700 transition-colors leading-snug">
              {post.frontmatter.title}
            </h3>
            
            <!-- Description -->
            <p class="text-sm text-gray-500 mb-6 line-clamp-2 flex-1 leading-relaxed">{post.frontmatter.description}</p>
            
            <!-- Footer row -->
            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <div class="flex items-center gap-1.5 text-xs text-gray-400 font-mono">
                <Calendar size={12} />
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
              <span class="flex items-center gap-1 text-xs font-semibold text-slate-400 group-hover:text-slate-800 transition-colors">
                Read <ArrowUpRight size={13} class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300" />
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <footer class="text-center text-xs text-gray-400 py-8">
    © 2026 Adarsh.dev
  </footer>
</Layout>

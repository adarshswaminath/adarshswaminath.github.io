---
import Layout from '../../layouts/Layout.astro'
import Section from '../../components/layout/Section.astro'
import Footer from '../../components/layout/Footer.astro'
import { ArrowRight } from 'lucide-astro'
import Navbar from '../../components/layout/Navbar.astro'
import type { MarkdownPost } from '../../data/types'

// Fetch all markdown posts
const posts = Object.values(
  import.meta.glob<MarkdownPost>('./*.md', { eager: true }),
)

// Sort by date DESC
const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.frontmatter.date).valueOf() -
    new Date(a.frontmatter.date).valueOf(),
)
---

<Layout title="Blog | Adarsh.dev">
  <Navbar />

  <Section
    id="blog-archive"
    title="Blog"
    heading="Writing & Thoughts"
  >
    <p class="mb-10 max-w-2xl text-[14px] leading-relaxed text-slate-500">
      Articles on Web3, React, scalable systems architecture, and my journey as
      a developer.
    </p>

    <div class="space-y-0">
      {
        sortedPosts.map((post) => (
          <a
            href={post.url}
            class="group row-hover-sheen -mx-4 block rounded-lg border-b border-dashed border-slate-300 px-4 py-5 transition-shadow duration-300 hover:shadow-[inset_0_-1px_0_0_rgb(226_232_240)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400"
          >
            <span
              class="row-hover-sheen__fill"
              aria-hidden="true"
            />
            <div class="relative z-10 flex items-center justify-between gap-6">
              <div class="min-w-0 flex-1">
                <div class="mb-1 flex items-center gap-3">
                  <span class="shrink-0 rounded bg-slate-100 px-2 py-0.5 font-mono text-[10px] font-semibold tracking-[0.15em] text-slate-400 uppercase">
                    {post.frontmatter.category || 'Article'}
                  </span>
                  <h3 class="truncate text-[15px] font-medium text-slate-900 transition-colors duration-300 group-hover:text-slate-800">
                    {post.frontmatter.title}
                  </h3>
                </div>
                <p class="truncate text-[13px] leading-relaxed text-slate-500">
                  {post.frontmatter.description}
                </p>
              </div>
              <div class="flex shrink-0 items-center gap-4">
                <span class="hidden font-mono text-[12px] text-slate-400 md:block">
                  {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </span>
                <ArrowRight
                  size={14}
                  class="shrink-0 text-slate-400 transition-transform duration-300 ease-out group-hover:translate-x-1 group-hover:text-slate-700"
                />
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Footer />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/layout/Footer.astro";
import { ArrowRight } from "lucide-astro";
import Navbar from "../../components/layout/Navbar.astro";

// Fetch all markdown posts
const posts = Object.values(import.meta.glob("./*.md", { eager: true }));

// Sort by date DESC
const sortedPosts = posts.sort(
  (a: any, b: any) =>
    new Date(b.frontmatter.date).valueOf() -
    new Date(a.frontmatter.date).valueOf(),
);
---

<Layout title="Blog | Adarsh.dev">
  <Navbar />

  <Section id="blog-archive" title="Blog" heading="Writing & Thoughts">
    <p class="text-[14px] text-slate-500 mb-10 max-w-2xl leading-relaxed">
      Articles on Web3, React, scalable systems architecture, and my journey as
      a developer.
    </p>

    <div class="space-y-0">
      {
        sortedPosts.map((post: any) => (
          <a
            href={post.url}
            class="group flex items-center justify-between gap-6 py-5 border-b border-slate-200/80 hover:bg-white/50 hover:-translate-y-1 transition-all duration-200 -mx-4 px-4 rounded-lg"
          >
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-1">
                <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-slate-400 bg-slate-100 px-2 py-0.5 rounded font-mono shrink-0">
                  {post.frontmatter.category || "Article"}
                </span>
                <h3 class="text-[15px] font-medium text-slate-900 group-hover:text-slate-700 transition-colors truncate">
                  {post.frontmatter.title}
                </h3>
              </div>
              <p class="text-[13px] text-slate-500 truncate leading-relaxed">
                {post.frontmatter.description}
              </p>
            </div>

            <div class="flex items-center gap-4 shrink-0">
              <span class="text-[12px] text-slate-400 font-mono hidden md:block">
                {new Date(post.frontmatter.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </span>
              <ArrowRight
                size={14}
                class="text-slate-400 group-hover:text-slate-700 group-hover:translate-x-1 transition-all duration-200"
              />
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Footer />
</Layout>

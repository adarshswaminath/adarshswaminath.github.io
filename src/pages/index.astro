---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Section from '../components/Section.astro';
import Tag from '../components/Tag.astro';
import ProjectDrawer from '../components/ProjectDrawer.astro';
import CodeWindow from '../components/CodeWindow.astro';
import { ArrowUpRight, ArrowRight, Calendar } from 'lucide-astro';

const navItems = ["About", "Projects", "Experience", "Blog", "Contact"];
const stackTags = ["React", "Next.js", "TypeScript", "Solidity", "Golang", "Tailwind"];

const projects = [

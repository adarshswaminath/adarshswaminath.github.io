// Fetch and sort blogs safely
const posts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));
const featuredBlogs = posts.sort((a: any, b: any) => 
  new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
).slice(0, 4);
---

<Layout>
  <!-- Tracing Beam -->
  <div class="fixed inset-y-0 w-full pointer-events-none z-50 flex justify-center">
    <div class="w-full max-w-5xl relative h-full">
      <div class="absolute left-3 md:left-[-1.5rem] top-0 bottom-0 py-24 w-[2px] hidden sm:block">
    <!-- Glowing Dot -->
    <div id="tracing-beam-dot" class="absolute top-[88px] -left-[7px] flex h-4 w-4 items-center justify-center rounded-full border shadow-sm transition-all duration-300 bg-white" style="border-color: rgba(0,0,0,0.24)">
      <div id="tracing-beam-inner-dot" class="h-2 w-2 rounded-full border bg-slate-800 transition-colors duration-300 border border-slate-900"></div>
    </div>

    <svg class="w-full h-full overflow-visible" preserveAspectRatio="none" viewBox="0 0 2 100">
      <!-- Background track -->
      <line x1="1" y1="0" x2="1" y2="100" stroke="#9091A0" stroke-opacity="0.16" stroke-width="1.5" vector-effect="non-scaling-stroke" stroke-linecap="round" />
      
      <!-- Animated beam -->
      <line x1="1" y1="0" x2="1" y2="100" stroke="url(#tracing-gradient)" stroke-width="2" vector-effect="non-scaling-stroke" stroke-linecap="round" />
      
      <defs>
        <linearGradient id="tracing-gradient" gradientUnits="userSpaceOnUse" x1="0" x2="0" y1="0" y2="-25">
          <stop stop-color="#0f172a" stop-opacity="0"></stop>
          <stop stop-color="#0f172a"></stop>
          <stop offset="0.325" stop-color="#334155"></stop>
          <stop offset="1" stop-color="#94a3b8" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
    </svg>
      </div>
    </div>
  </div>


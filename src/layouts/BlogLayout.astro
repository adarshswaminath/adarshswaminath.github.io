---
import Layout from './Layout.astro';
import Section from '../components/Section.astro';

const { frontmatter } = Astro.props;
---
<Layout title={`${frontmatter.title} - Adarsh.dev`} description={frontmatter.description}>
  <nav class="sticky top-0 bg-[#F1F1F1]/90 backdrop-blur border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center text-sm">
      <a href="/" class="font-semibold text-gray-800">Adarsh.dev</a>
      <a href="/blog" class="hover:underline text-gray-600">Back to Blog</a>
    </div>
  </nav>

  <Section title={frontmatter.title}>
    <div class="mb-8 border-b border-gray-200 pb-4">
      <div class="text-sm text-gray-500">
        <time datetime={frontmatter.date}>{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
    </div>

    <article class="prose max-w-none text-gray-800">
      <slot />
    </article>
  </Section>
  
  <footer class="text-center text-xs text-gray-400 py-8">
    © 2026 Adarsh.dev
  </footer>
</Layout>


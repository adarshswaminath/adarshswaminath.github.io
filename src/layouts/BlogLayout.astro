---
import Layout from './Layout.astro';
import Section from '../components/Section.astro';

const { frontmatter } = Astro.props;
---
<Layout title={`${frontmatter.title} - Adarsh.dev`} description={frontmatter.description}>
  <nav class="sticky top-0 bg-[#F1F1F1]/90 backdrop-blur border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center text-sm">
      <a href="/" class="font-semibold text-gray-800">Adarsh.dev</a>
      <a href="/blog" class="hover:underline text-gray-600">Back to Blog</a>
    </div>
  </nav>

  <Section id="article" title={frontmatter.category || "Article"} heading={frontmatter.title}>
    <div class="mb-8 border-b border-gray-200 pb-4">
      <div class="text-sm text-gray-500">
        <time datetime={frontmatter.date}>{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
    </div>

    <article class="prose max-w-none text-gray-800">
      <slot />
    </article>
  </Section>
  
  <footer class="text-center text-xs text-gray-400 py-8">
    © 2026 Adarsh.dev
  </footer>
</Layout>

<style is:global>
  /* Style markdown code blocks in blog posts to look like CodeWindow */
  .prose pre {
    position: relative;
    padding-top: 3.5rem !important; /* 44px + 12px */
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
    padding-bottom: 1.5rem !important;
    border-radius: 0.75rem !important; /* xl */
    border: 1px solid rgba(229, 231, 235, 0.8) !important;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    background-color: #fdfdfd !important;
    margin-top: 2rem;
    margin-bottom: 2rem;
    overflow-x: auto;
  }

  /* Header Bar */
  .prose pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2.75rem; /* 44px */
    background-color: #f5f5f5;
    border-bottom: 1px solid rgba(229, 231, 235, 0.8);
    pointer-events: none;
  }

  /* Mac Dots */
  .prose pre::after {
    content: '';
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 0.75rem; /* 12px */
    height: 0.75rem; /* 12px */
    border-radius: 9999px;
    background-color: #d1d5db; /* gray-300 */
    box-shadow: 1.25rem 0 0 0 #d1d5db, 2.5rem 0 0 0 #d1d5db;
    z-index: 10;
  }

  .prose pre code {
    background: transparent !important;
    font-family: inherit;
    font-size: 0.875rem;
    display: block;
  }
</style>


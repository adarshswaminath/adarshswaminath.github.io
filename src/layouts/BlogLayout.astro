---
import Layout from "./Layout.astro";
import Section from "../components/layout/Section.astro";

const { frontmatter } = Astro.props;
---

<Layout
  title={`${frontmatter.title} - Adarsh.dev`}
  description={frontmatter.description}
>
  <nav
    class="sticky top-0 bg-[#F1F1F1]/90 backdrop-blur border-b border-slate-200"
  >
    <div
      class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center text-sm"
    >
      <a href="/" class="font-semibold text-slate-800">Adarsh.dev</a>
      <a href="/blog" class="hover:underline text-slate-600">Back to Blog</a>
    </div>
  </nav>

  <Section
    id="article"
    title={frontmatter.category || "Article"}
    heading={frontmatter.title}
  >
    <div class="mb-8 border-b border-slate-200 pb-4">
      <div class="text-sm text-slate-500">
        <time datetime={frontmatter.date}
          >{
            new Date(frontmatter.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }</time
        >
      </div>
    </div>

    <article class="prose max-w-none text-slate-800">
      <slot />
    </article>
  </Section>

  <footer class="text-center text-xs text-slate-400 py-8">
    © 2026 Adarsh.dev
  </footer>
</Layout>

<style is:global>
  /* Style markdown code blocks in blog posts to look like CodeWindow */
  .prose pre {
    position: relative;
    padding-top: 3rem !important;
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
    padding-bottom: 1.5rem !important;
    border-radius: 0.75rem !important;
    border: 1px solid #334155 !important;
    background-color: #0f172a !important; /* Dark slate-950 background */
    margin-top: 2rem;
    margin-bottom: 2rem;
    overflow-x: auto;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  /* Header Bar */
  .prose pre::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2.5rem;
    background-color: #1e293b; /* slate-800 */
    border-bottom: 1px solid #334155;
    pointer-events: none;
  }

  /* Mac Dots */
  .prose pre::after {
    content: "";
    position: absolute;
    top: 0.875rem;
    left: 1rem;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background-color: #ef4444; /* Red dot */
    box-shadow:
      1.1rem 0 0 0 #f59e0b, /* Orange dot */
      2.2rem 0 0 0 #10b981; /* Green dot */
    z-index: 10;
  }

  .prose pre code {
    background: transparent !important;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875rem;
    color: #e2e8f0 !important; /* Light slate-200 text */
    display: block;
    line-height: 1.6;
  }
</style>

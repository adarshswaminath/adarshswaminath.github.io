---
import "../styles/global.css";
import { ClickSpark } from "../components/ui";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Adarsh - Portfolio",
  description = "Full Stack JavaScript Developer",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-sans: "Manrope", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
      }
      body {
        font-family: var(--font-sans);
        font-optical-sizing: auto;
        font-weight: 400;
        font-style: normal;
      }
      pre,
      code {
        font-family: var(--font-mono);
      }
    </style>
  </head>
  <body class="bg-[#F1F1F1] text-slate-800">
    <div class="fixed inset-0 pointer-events-none flex justify-center z-0">
      <div class="w-full max-w-5xl border-x border-dashed border-slate-300">
      </div>
    </div>
    <div class="relative z-10 w-full overflow-hidden">
      <slot />
    </div>
    <ClickSpark />
  </body>
</html>
